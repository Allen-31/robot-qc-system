<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zioneer.robotqcsystem.mapper.SysMenuMapper">

    <resultMap id="BaseResultMap" type="com.zioneer.robotqcsystem.domain.entity.SysMenu">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name_key" property="nameKey"/>
        <result column="path" property="path"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="icon" property="icon"/>
        <result column="permission" property="permission"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, code, name_key, path, parent_id, sort_order, icon, permission, status, created_at, updated_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_menu WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_menu WHERE code = #{code}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_menu
        <if test="status != null and status != ''">
            WHERE status = #{status}
        </if>
        ORDER BY parent_id ASC NULLS FIRST, sort_order ASC, id ASC
    </select>

    <select id="selectByParentId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_menu
        <where>
            <choose>
                <when test="parentId == null">
                    AND parent_id IS NULL
                </when>
                <otherwise>
                    AND parent_id = #{parentId}
                </otherwise>
            </choose>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="countByParentId" resultType="int">
        SELECT COUNT(*) FROM sys_menu
        <where>
            <choose>
                <when test="parentId == null">
                    AND parent_id IS NULL
                </when>
                <otherwise>
                    AND parent_id = #{parentId}
                </otherwise>
            </choose>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_menu (code, name_key, path, parent_id, sort_order, icon, permission, status, created_at, updated_at)
        VALUES (#{code}, #{nameKey}, #{path}, #{parentId}, #{sortOrder}, #{icon}, #{permission}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateById">
        UPDATE sys_menu
        <set>
            <if test="nameKey != null">name_key = #{nameKey},</if>
            <if test="path != null">path = #{path},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="permission != null">permission = #{permission},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_menu WHERE id = #{id}
    </delete>
</mapper>
